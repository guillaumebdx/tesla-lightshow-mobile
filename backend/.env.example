# OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# OpenAI model for light show generation
OPENAI_MODEL=gpt-4.1-mini

# OpenAI model for support chat AI drafts (can differ from show generation)
OPENAI_CHAT_MODEL=gpt-4.1-nano

# Firebase service account JSON path (relative to backend/)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Server port
PORT=3001

# Allowed origin (your app's domain, or * for dev)
CORS_ORIGIN=*

# Node environment (development = skip App Check)
NODE_ENV=development

# Admin password for /admin routes
ADMIN_PASSWORD=your-secret-password-here
